# Leave empty for Docker dev mode; Vite proxies /v1 to api:8000.
VITE_API_BASE_URL=

# Admin API token for local development.
ADMIN_TOKEN=change-me

# Optional: direct URL for the large retrain feature store artifact.
# Store this file outside Git, for example in GitHub Releases, S3, or HuggingFace.
MODEL_FEATURE_STORE_URL=

# Optional but recommended: sha256 for the downloaded .npz.
MODEL_FEATURE_STORE_SHA256=
