APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=postgresql+asyncpg://artstyle:artstyle@postgres:5432/artstyle
DATABASE_URL_SYNC=postgresql+psycopg://artstyle:artstyle@postgres:5432/artstyle
MLFLOW_DATABASE_URL_SYNC=postgresql+psycopg2://artstyle:artstyle@postgres:5432/postgres
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_QUEUE_NAME=artstyle.inference
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=artstyle-images
S3_PRESIGN_TTL_SECONDS=3600
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_S3_BUCKET=mlflow-artifacts
DEFAULT_MODEL_NAME=art-style-classifier
DEFAULT_MODEL_VERSION=stub-v1
DEFAULT_MODEL_SOURCE=internal_stub
ADMIN_TOKEN=change-me
UPLOAD_MAX_SIZE_MB=10
DEFAULT_TOP_K=5
LOG_LEVEL=INFO
